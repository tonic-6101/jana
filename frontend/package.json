    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.4.0",
    "vite": "^4.4.9",
    "vue-tsc": "^2.0.0"
  }
