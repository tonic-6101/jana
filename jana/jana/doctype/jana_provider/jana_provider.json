 "fields": [
  {
   "fieldname": "provider_name",
   "fieldtype": "Data",
   "in_list_view": 1,
   "label": "Provider Name",
   "reqd": 1,
   "unique": 1
  },
  {
   "fieldname": "provider_type",
   "fieldtype": "Select",
   "in_list_view": 1,
   "label": "Provider Type",
   "options": "openai\nanthropic\ngoogle\nopenrouter\nollama\nvllm\ncustom",
   "reqd": 1
  },
  {
   "fieldname": "column_break_config",
   "fieldtype": "Column Break"
  },
  {
   "default": "1",
   "fieldname": "enabled",
   "fieldtype": "Check",
   "in_list_view": 1,
   "label": "Enabled"
  },
  {
   "default": "0",
   "fieldname": "is_default",
   "fieldtype": "Check",
   "label": "Is Default"
  },
  {
   "fieldname": "connection_section",
   "fieldtype": "Section Break",
   "label": "Connection"
  },
  {
   "default": "API Key",
   "depends_on": "eval:!['ollama','vllm'].includes(doc.provider_type)",
   "fieldname": "auth_method",
   "fieldtype": "Select",
   "in_list_view": 1,
   "label": "Authentication",
   "options": "API Key\nOAuth",
   "reqd": 1
  },
  {
   "depends_on": "eval:doc.auth_method == 'API Key'",
   "fieldname": "api_key",
   "fieldtype": "Password",
   "label": "API Key"
  },
  {
   "fieldname": "column_break_connection",
   "fieldtype": "Column Break"
  },
  {
   "description": "Required for Ollama, vLLM, or custom endpoints. Set to https://openrouter.ai/api/v1 for OpenRouter.",
   "fieldname": "api_base_url",
   "fieldtype": "Data",
   "label": "API Base URL"
  },
  {
   "depends_on": "eval:doc.auth_method == 'OAuth'",
   "fieldname": "oauth_section",
   "fieldtype": "Section Break",
   "label": "OAuth Configuration"
  },
  {
   "depends_on": "eval:doc.auth_method == 'OAuth' && doc.provider_type == 'google'",
   "description": "Link to a Frappe Connected App configured for Google OAuth",
   "fieldname": "connected_app",
   "fieldtype": "Link",
   "label": "Connected App",
   "mandatory_depends_on": "eval:doc.auth_method == 'OAuth' && doc.provider_type == 'google'",
   "options": "Connected App"
  },
  {
   "depends_on": "eval:doc.auth_method == 'OAuth' && doc.provider_type == 'openrouter'",
   "description": "Users will be redirected to OpenRouter to authorize, then back to this URL",
   "fieldname": "openrouter_callback_url",
   "fieldtype": "Data",
   "label": "OAuth Callback URL",
   "read_only": 1
  },
  {
   "fieldname": "models_section",
   "fieldtype": "Section Break",
   "label": "Models"
  },
  {
   "description": "Comma-separated list of available model names",
   "fieldname": "available_models",
   "fieldtype": "Small Text",
   "label": "Available Models"
  },
  {
   "fieldname": "column_break_models",
   "fieldtype": "Column Break"
  },
  {
   "default": "Auto-detect",
   "description": "Controls guardrail strictness. Auto-detect uses the model name to determine the tier. Tier 3 (Weak) applies maximum guardrails.",
   "fieldname": "provider_tier",
   "fieldtype": "Select",
   "label": "Provider Tier",
   "options": "Auto-detect\nTier 1 (Strong)\nTier 2 (Medium)\nTier 3 (Weak)"
  },
  {
   "fieldname": "privacy_section",
   "fieldtype": "Section Break",
   "label": "Privacy"
  },
  {
   "default": "Global Default",
   "description": "Override the global PII masking setting for this provider. 'Global Default' inherits from Jana Settings.",
   "fieldname": "mask_pii_override",
   "fieldtype": "Select",
   "label": "PII Masking",
   "options": "Global Default\nAlways On\nAlways Off"
  }
